    4) printing the values inyaml using double flower braces {{a}}
    5)cmds to executing the play books
        cmds:
            - ansible-playbokk playbook-name -b
            - ansible-playbokk playbook-name --syntax-check
            - ansible-playbokk playbook-name --check   --> dry run
            - ansible-playbokk playbook-name --list-hosts
            - ansible-playbook playbook-name --extra-vars "v1=10 v2=20"
